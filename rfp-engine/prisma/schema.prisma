generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models
model User {
  id                      String         @id @default(cuid())
  name                    String?
  email                   String         @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?
  plan                    Plan           @default(FREE)
  stripeCustomerId        String?        @unique
  stripeSubscriptionId    String?        @unique
  subscriptionStatus      SubscriptionStatus?
  currentPeriodEnd        DateTime?      // When current billing period ends
  cancelAtPeriodEnd       Boolean        @default(false) // User cancelled but access until period end
  monthlyExtractionsUsed  Int            @default(0)
  monthlyExtractionsLimit Int            @default(2)
  lastUsageReset          DateTime       @default(now())

  // Consent tracking (GDPR compliance)
  termsAcceptedAt         DateTime?
  privacyPolicyAcceptedAt DateTime?
  marketingConsentGiven   Boolean        @default(false)
  cookieConsentGiven      Boolean        @default(false)

  // CCPA compliance
  doNotSellData           Boolean        @default(false)

  // Soft delete for audit trail
  deletedAt               DateTime?

  // Two-Factor Authentication (2FA)
  twoFactorEnabled        Boolean        @default(false)
  twoFactorSecret         String?        // Encrypted TOTP secret
  twoFactorBackupCodes    String[]       // Hashed backup codes
  twoFactorVerifiedAt     DateTime?      // When 2FA was successfully set up

  // Relations
  accounts                Account[]
  sessions                Session[]
  projects                Project[]
  pastResponses           PastResponse[]
  consentLogs             ConsentLog[]
  auditLogs               AuditLog[]
  dataExportRequests      DataExportRequest[]
  requirementVersions     RequirementVersion[]

  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

enum Plan {
  FREE
  SOLO
  PRO
  TEAM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

model Project {
  id               String          @id @default(cuid())
  name             String
  companyName      String?
  fileName         String
  fileUrl          String?
  rawText          String          @db.Text
  deadline         DateTime?       // Extracted submission deadline
  deadlineText     String?         // Original deadline text from RFP
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  requirements     Requirement[]
  exports          ProjectExport[] // Cached document exports
  status           ProjectStatus   @default(PROCESSING)
  // Deadline reminder tracking
  lastReminderSent DateTime?       // When last reminder was sent
  lastReminderType String?         // "7d", "3d", "1d", "overdue"
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@index([deadline])
}

enum ProjectStatus {
  PROCESSING
  READY
  COMPLETED
  FAILED
}

model Requirement {
  id             String               @id @default(cuid())
  projectId      String
  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  text           String               @db.Text
  section        String?
  isMandatory    Boolean              @default(false)
  draftAnswer    String?              @db.Text
  internalNotes  String?              @db.Text  // Private notes, not exported
  wordLimit      Int?                 // Max words extracted from RFP
  characterLimit Int?                 // Max characters extracted from RFP
  status         RequirementStatus    @default(UNANSWERED)
  type           RequirementType      @default(DECLARATIVE)
  domainContext  DomainContext        @default(FEATURE)
  requiresReview   Boolean              @default(false)
  isManuallyAdded  Boolean              @default(false) // User-created requirement
  order            Int
  versions         RequirementVersion[] // Version history for draft answers
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([projectId])
}

// Version history for requirement draft answers
model RequirementVersion {
  id            String            @id @default(cuid())
  requirementId String
  requirement   Requirement       @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  draftAnswer   String            @db.Text
  status        RequirementStatus
  editedById    String
  editedBy      User              @relation(fields: [editedById], references: [id])
  changeSource  String?           // "manual", "ai_generated", "library_insert", "restored"
  createdAt     DateTime          @default(now())

  @@index([requirementId])
  @@index([editedById])
  @@index([requirementId, createdAt(sort: Desc)])
}

enum RequirementStatus {
  UNANSWERED
  PARTIAL
  ANSWERED
}

enum RequirementType {
  PROCEDURAL
  DECLARATIVE
  DESCRIPTIVE
  EVIDENCE_BASED
  CONTEXTUAL
  QUANTITATIVE
  REFERENCE_BASED
  STAFFING
}

enum DomainContext {
  FEATURE
  PROCESS
  LEGAL
}

model PastResponse {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  tags       String[]
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, usageCount(sort: Desc)])
}

// =============================================================================
// COMPLIANCE MODELS (GDPR, CCPA)
// =============================================================================

// Tracks all consent events for legal compliance
model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType String   // "terms", "privacy", "marketing", "cookies", "dpa"
  granted     Boolean  // true = consent given, false = consent revoked
  ipAddress   String?
  userAgent   String?
  version     String   // Policy version consented to (e.g., "1.0", "2024-01-01")
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([consentType])
}

// Audit trail for all significant user actions (GDPR Art. 30)
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // e.g., "user.login", "project.create", "data.export"
  resource   String?  // e.g., "project", "requirement", "user"
  resourceId String?  // ID of the affected resource
  details    Json?    // Additional context (changed fields, etc.)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Tracks data export requests (GDPR Art. 20 - Data Portability)
model DataExportRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("pending") // "pending", "processing", "completed", "failed"
  format      String    @default("json")    // "json", "csv"
  downloadUrl String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([status])
}

// =============================================================================
// PASSWORD RESET
// =============================================================================

// Secure password reset tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime? // Set when token is used to prevent reuse

  @@index([email])
  @@index([token])
}

// =============================================================================
// 2FA PENDING SESSIONS
// =============================================================================

// Stores pending 2FA login sessions (replaces in-memory Map)
model Pending2FASession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

// =============================================================================
// WEBHOOK IDEMPOTENCY
// =============================================================================

// Tracks processed Stripe webhook events to prevent duplicate processing
model ProcessedWebhookEvent {
  id        String   @id // Use Stripe event ID
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// =============================================================================
// DOCUMENT EXPORT
// =============================================================================

// Cached document exports for re-download without regeneration
model ProjectExport {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  format    String   // "docx" or "pdf"
  template  String   // "compliance-matrix" or "qa-format"
  isDraft   Boolean  @default(false) // If exported with unresolved placeholders (watermarked)
  fileName  String   // Generated filename
  fileData  Bytes    // Stored file content
  fileSize  Int      // Size in bytes
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, format, template])
}
