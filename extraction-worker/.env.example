# Required
GEMINI_API_KEY=

# Required in production. Must match the main application's value.
EXTRACTION_WORKER_KEY=replace-with-a-long-random-secret

# Browser origins allowed to call the service directly.
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Hosts accepted for asynchronous webhook callbacks.
ALLOWED_WEBHOOK_HOSTS=localhost,vercel.app,rfpmatrix.com

# Runtime
PORT=3001
NODE_ENV=development
