# Required
OPENAI_API_KEY=sk-...

# Optional - for securing the endpoint (must match main app's EXTRACTION_WORKER_KEY)
EXTRACTION_WORKER_KEY=your-secret-key-here

# Optional - CORS origins (comma-separated)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Optional - port (default: 3001)
PORT=3001
